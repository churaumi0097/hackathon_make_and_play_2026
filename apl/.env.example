# ===========================================================================
# バックエンド（Django）環境変数のサンプル。
# このファイルをコピーして apl/.env を作成し、値を埋めてください。
#   cp apl/.env.example apl/.env
# .env は .gitignore 済み。シークレットはコミットしないこと。
# ===========================================================================

# Django
DEBUG=True
# 本番用に必ず変更する
# DJANGO_SECRET_KEY=change-me
# ALLOWED_HOSTS=localhost,127.0.0.1
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- 外部 API キー（サーバー側のみ。絶対にフロントへ出さない） ---
# Gemini（感情解析・メッセージ生成）
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Google Maps サーバーキー（Places API / Directions API 用）
# ※ フロント地図表示用の "ブラウザキー" とは別に用意し、
#   こちらはリファラ制限ではなく IP 制限＋API 制限をかけること。
GOOGLE_MAPS_SERVER_KEY=
